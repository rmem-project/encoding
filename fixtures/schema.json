{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rmem.local/encoding/fixtures.schema.json",
  "title": "@rmem/encoding fixture manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["fixtures"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "fixtures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fixture"
      }
    }
  },
  "$defs": {
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "expected"],
      "oneOf": [
        {
          "required": ["bytesPath"],
          "not": {
            "required": ["bytesHex"]
          }
        },
        {
          "required": ["bytesHex"],
          "not": {
            "required": ["bytesPath"]
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "bytesPath": {
          "type": "string",
          "minLength": 1
        },
        "bytesHex": {
          "type": "string",
          "pattern": "^(?:\\s|0x|[0-9a-fA-F])+$"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected": {
          "$ref": "#/$defs/expected"
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string"
        },
        "detection": {
          "$ref": "#/$defs/detection"
        },
        "lineIndex": {
          "$ref": "#/$defs/lineIndex"
        },
        "offsetMap": {
          "$ref": "#/$defs/offsetMap"
        }
      }
    },
    "detection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "encoding": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "bomLength": {
          "type": "integer",
          "minimum": 0
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "lineIndex": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lineCount": {
          "type": "integer",
          "minimum": 0
        },
        "lines": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lineExpectation"
          }
        }
      }
    },
    "lineExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line"],
      "properties": {
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "textRange": {
          "$ref": "#/$defs/range"
        },
        "byteRange": {
          "$ref": "#/$defs/range"
        }
      }
    },
    "offsetMap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ranges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/offsetRange"
          }
        }
      }
    },
    "offsetRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "textRange", "byteRange"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "textRange": {
          "$ref": "#/$defs/range"
        },
        "byteRange": {
          "$ref": "#/$defs/range"
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "end": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
